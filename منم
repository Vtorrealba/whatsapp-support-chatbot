 * Code Example (Python/FastAPI - Core Logic):
   # core/services.py
import magic
import os
import uuid

class FileValidationService:
    def __init__(self, settings):
        self.settings = settings

    def validate_mime_type(self, file_path: str) -> str:
        mime = magic.Magic(mime=True)
        mime_type = mime.from_file(file_path)
        if mime_type not in self.settings.allowed_mime_types:
            raise ValueError(f"Invalid MIME type: {mime_type}")
        return mime_type

    def generate_unique_file_id(self) -> str:
        return str(uuid.uuid4())

class FileStorageService:
    def __init__(self, settings):
        self.settings = settings

    def save_file(self, file_path: str, content: bytes) -> None:
        os.makedirs(os.path.dirname(file_path), exist_ok=True)
        with open(file_path, "wb") as f:
            f.write(content)

    def delete_file(self, file_path: str) -> None:
        if os.path.exists(file_path):
            os.remove(file_path)

